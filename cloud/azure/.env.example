# Copy to .env and fill in after running setup_azure.ps1 (which prints these).
#   Copy-Item cloud/azure/.env.example cloud/azure/.env
# .env is git-ignored; .env.example is the template. Used by gen_deployment.ps1.

# Azure Container Registry (from setup_azure.ps1 output / `az acr credential show`)
ACR_NAME=heatstrainacr
ACR_ADDRESS=heatstrainacr.azurecr.io
ACR_USERNAME=heatstrainacr
ACR_PASSWORD=REPLACE_WITH_ACR_PASSWORD

# The posture-api module image (must match build_and_push.ps1)
MODULE_IMAGE=heatstrainacr.azurecr.io/posture-api:v3

# Host path bind-mounted into the module as /data (model + training records).
# Use FORWARD SLASHES so Docker Desktop accepts the bind on Windows.
HOST_DATA_PATH=C:/Users/User/Project/iot/data

# IoT Hub + Edge device (from setup_azure.ps1 output) — used by run_edge.ps1
IOT_HUB_NAME=heat-strain-hub
EDGE_DEVICE_ID=dorm-edge
